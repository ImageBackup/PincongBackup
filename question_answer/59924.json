      "discussions": []
    },
    {
      "id": "670845",
      "is_folded": false,
      "answerer": {
        "username": "negi",
        "uid": "74403"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t冷战的装甲洪流就是苏修吹牛逼搞宣传战骗国内傻子，然后美帝军队借机宣传苏修威胁论骗国防经费经费的一个愿打一个愿挨的闹剧。不会真有人当真了，以为这玩意有战斗力了吧。\t\t</div>",
      "date": "2023-07-15",
      "agree_count": 2,
      "discussion_count": 0,
      "discussions": []
    },
