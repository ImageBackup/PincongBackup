    {
      "id": "611595",
      "is_folded": false,
      "answerer": {
        "username": "藤井雅樹",
        "uid": "83175"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t當國家屬於人民，你只需要愛自己。因為你就是人民，你就是國家。<br/>\n<br/>\n當國家屬於黨，你更不需要愛國。因為那個國是黨的，不是你的。<br/>\n<br/>\n不需要愛國。\t\t</div>",
      "date": "2022-12-17",
