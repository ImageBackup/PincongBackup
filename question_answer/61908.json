      "discussions": []
    },
    {
      "id": "690506",
      "is_folded": false,
      "answerer": {
        "username": "姒越兴",
        "uid": "112667"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t海参崴那是孝敬爹的，对爹怎么敢指手画脚，况且海参崴的华人也早就赶走得差不多了，少了一个借口借题发挥。<br/>\n台湾就不一样，只要共匪一天没消灭中华民国，自身的合法性就永远无法成立。\t\t</div>",
      "date": "2023-09-20",
      "agree_count": 7,
      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "690546",
      "is_folded": false,
      "answerer": {
