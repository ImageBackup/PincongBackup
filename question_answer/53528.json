    {
      "id": "613444",
      "is_folded": false,
      "answerer": {
        "username": "gameboyxx",
        "uid": "82367"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t新加坡那样的低税收实现居者有其屋的”低福利”\t\t</div>",
      "date": "2022-12-23",
