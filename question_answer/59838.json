    {
      "id": "687004",
      "is_folded": false,
      "answerer": {
        "username": "Vinobianco",
        "uid": "93938"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t独裁政权的权利都没法顺利交接<br/>\n紫薯紫薯紫薯紫薯紫薯紫薯紫薯紫薯\t\t</div>",
      "date": "2023-09-07",
