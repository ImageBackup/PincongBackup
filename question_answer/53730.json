      "discussions": []
    },
    {
      "id": "605203",
      "is_folded": false,
      "answerer": {
        "username": "ejdw32",
        "uid": "93484"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t中共是0分，香港台湾是90分。90分看不起0分吗？就算面子上不说，内心里怎么想呢。中共和港台没有关系。中共民主需要自己争取。台湾香港的民主需要自己守护。\t\t</div>",
      "date": "2022-12-02",
