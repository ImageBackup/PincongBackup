      "discussions": []
    },
    {
      "id": "666642",
      "is_folded": false,
      "answerer": {
        "username": "事已至此先吃饭吧",
        "uid": "102283"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t如果普京进入了特工所习惯的自毁模式，那炸了也就炸了，把乌克兰和俄罗斯以及东欧的未来葬送，北约对乌的援助力度依然偏弱，自己又迟迟不下场，拖久了什么坏事都会发生，做最坏的预计核电站真有不小的概率被炸掉。\t\t</div>",
      "date": "2023-07-01",
