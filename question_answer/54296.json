    {
      "id": "610990",
      "is_folded": false,
      "answerer": {
        "username": "toyoo",
        "uid": "105290"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t我还正想提问呢，最近我在老家，发现有老奶奶在种火麻子，我看到叶子好像在哪见过，后来用软件识别了才发现是大麻，不过这个显然因为授粉，没有成为品质最好的<a class=\"placeholder\" href=\"url/img/aHR0cHM6Ly90ZWxlZ3JhLnBoL2ZpbGUvMGRkZTRkZjQxNWIxZGJkYTIyODU5LmpwZw\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://telegra.ph/file/0dde4df415b1dbda22859.jpg\"><img alt=\"https://telegra.ph/file/0dde4df415b1dbda22859.jpg\" loading=\"lazy\" src=\"https://telegra.ph/file/0dde4df415b1dbda22859.jpg\" style=\"max-width:100%\"/></a> </div>",
      "date": "2022-12-15",
