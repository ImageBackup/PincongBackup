      "discussions": []
    },
    {
      "id": "738749",
      "is_folded": false,
      "answerer": {
        "username": "平疫禁人忍民领袖",
        "uid": "105080"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t我怀疑你和我看的是不是同一个品葱，我看的品葱两三个贴里必有一个有屠支大佐暴论<br/>\n<br/>\n另外民主从来都是奢侈品，真正的民主离不开自由，即新闻自由、言论自由、迁徙自由等。\t\t</div>",
      "date": "2024-04-06",
      "agree_count": 3,
      "discussion_count": 1,
      "discussions": [
