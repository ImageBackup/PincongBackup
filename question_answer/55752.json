      "answerer": {
        "username": "CrushSummer",
        "uid": "107581"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t沉默者与帝王同罪<br/>\n所有的灾难都源于集体的沉默\t\t</div>",
      "date": "2023-02-04",
