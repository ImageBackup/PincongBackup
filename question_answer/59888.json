      "is_folded": false,
      "answerer": {
        "username": "c2h4",
        "uid": "101813"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t有人想做掉他，躲躲风头，我也是刚刚得到的传闻\t\t</div>",
      "date": "2023-07-17",
