    {
      "id": "660529",
      "is_folded": false,
      "answerer": {
        "username": "Fake_id",
        "uid": "74574"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t依序记得小时候在深圳城中村里看到的狗肉摊，直接把狗头挂在那，真的好恶心，野蛮…\t\t</div>",
