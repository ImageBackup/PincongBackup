      "discussions": []
    },
    {
      "id": "731643",
      "is_folded": false,
      "answerer": {
        "username": "Vinobianco",
        "uid": "93938"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t全世界都在通胀消解债务 中国现在是想要通胀而不得\t\t</div>",
      "date": "2024-03-03",
