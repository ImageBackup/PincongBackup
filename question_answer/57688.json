      "discussions": []
    },
    {
      "id": "691569",
      "is_folded": false,
      "answerer": {
        "username": "铁甲小驴",
        "uid": "111516"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t作者總結的是昭和時期的日本人，當今的日本人已經和幾十年前被稱作的「拼命三郎」的日本人有著天壤之別！\t\t</div>",
      "date": "2023-09-23",
