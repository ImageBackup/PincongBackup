    },
    {
      "id": "722405",
      "is_folded": false,
      "answerer": {
        "username": "维尼之父",
        "uid": "112102"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t民主和富裕没必然关系，但民主一定会带来相对的公平公正，以及缩小贫富差距\t\t</div>",
      "date": "2024-01-23",
