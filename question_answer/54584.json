    {
      "id": "613871",
      "is_folded": false,
      "answerer": {
        "username": "西曹县韭菜包子",
        "uid": "101894"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t小米红米手机要用miui12系统。20年底的miui13系统也不安全，已经自动安装了反诈中心app\t\t</div>",
      "date": "2022-12-25",
