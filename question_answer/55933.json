    {
      "id": "629332",
      "is_folded": false,
      "answerer": {
        "username": "对不起伤害了你",
        "uid": "104840"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t换个问题，如果美国ChatGPT没出来，中国互联网公司照什么抄呢？\t\t</div>",
      "date": "2023-02-08",
