      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "733101",
      "is_folded": false,
      "answerer": {
        "username": "xxniming",
        "uid": "119060"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t教金融的主要目的是把握机会，金融内卷有利于反垄断。\t\t</div>",
