    {
      "id": "726746",
      "is_folded": false,
      "answerer": {
        "username": "东北大葱",
        "uid": "123279"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t中医学是起源于中国的传统医学，其理论和实践在历史上通过文化交流传入日本。在东亚文化圈中，文学、艺术、哲学和医学等方面的知识传播历史悠久。日本在接触中医学后，结合自己的实际情况，形成了独特的汉医学传统，即\"汉方医学\"。\t\t</div>",
      "date": "2024-02-08",
      "agree_count": 0,
      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "726764",
      "is_folded": false,
