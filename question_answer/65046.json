      "contents": "<div class=\"markitup-box\">\n<a class=\"placeholder\" href=\"url/img/aHR0cHM6Ly90ZWxlZ3JhLnBoL2ZpbGUvNGQ1M2IzY2M5M2RiNjMwM2ZhYTZkLmpwZz93aWR0aD0xMjMyJmhlaWdodD05Mjg\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://telegra.ph/file/4d53b3cc93db6303faa6d.jpg?width=1232&amp;height=928\"><img alt=\"https://telegra.ph/file/4d53b3cc93db6303faa6d.jpg?width=1232&amp;height=928\" loading=\"lazy\" src=\"https://telegra.ph/file/4d53b3cc93db6303faa6d.jpg?width=1232&amp;height=928\" style=\"max-width:100%\"/></a> </div>",
