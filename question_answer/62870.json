      "discussions": []
    },
    {
      "id": "702633",
      "is_folded": false,
      "answerer": {
        "username": "不喜歡學習",
        "uid": "118757"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t習在想什麼，誰也不知道，誰干不重要，看這類事要看政治價值，社會價值，李克強的死帶來的政治價值和社會價值非常重要\t\t</div>",
      "date": "2023-11-01",
