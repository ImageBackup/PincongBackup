    {
      "id": "645327",
      "is_folded": false,
      "answerer": {
        "username": "kane888",
        "uid": "31952"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t收租应该没有什么问题，坏的是户籍制度，地域发展极不平衡，农民工进城\t\t</div>",
