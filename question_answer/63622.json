    {
      "id": "709011",
      "is_folded": false,
      "answerer": {
        "username": "长歌当哭",
        "uid": "85967"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t长痛不如短痛。<br/>\n<br/>\nCCP不倒台 子子孙孙被奴役<br/>\n<br/>\n经济崩溃 CCP倒台<br/>\n<br/>\n是短痛\t\t</div>",
