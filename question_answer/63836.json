    {
      "id": "711407",
      "is_folded": false,
      "answerer": {
        "username": "之江新军",
        "uid": "92363"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t正因为习近平同志韬光养晦，看似人畜无害，政治老人们才放心把国家主席的虚衔交给她。\t\t</div>",
