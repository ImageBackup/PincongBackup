    {
      "id": "692478",
      "is_folded": false,
      "answerer": {
        "username": "The19890604",
        "uid": "46798"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t缺乏戰爭潛力，並不是說俄羅斯缺人，而是俄羅斯缺重工業<br/>\n<br/>\n蘇聯鋼鐵洪流遺產一輛接著一輛爆金幣，俄羅斯實在無力開闢第二戰場<br/>\n<br/>\n俄羅斯選擇烏克蘭是有理由的，烏克蘭曾經是蘇聯時期的軍事工業重鎮<br/>\n<br/>\n亞速鋼鐵廠就是蘇聯曾經的輝煌\t\t</div>",
      "date": "2023-09-27",
      "agree_count": 3,
      "discussion_count": 4,
      "discussions": [
        {
          "id": "1211632",
          "replier": {
