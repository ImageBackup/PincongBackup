    {
      "id": "680323",
      "is_folded": false,
      "answerer": {
        "username": "fb_china_today",
        "uid": "8633"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t开弓没有回头见<br/>\n<br/>\n习主席和共产党长期错误决策给自己断了后路<br/>\n<br/>\n俄罗斯就比他高明许多\t\t</div>",
      "date": "2023-08-16",
