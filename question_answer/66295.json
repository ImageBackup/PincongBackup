      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "737617",
      "is_folded": false,
      "answerer": {
        "username": "wce3f2xi",
        "uid": "49662"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t买过低端机，同价位硬件不行，直接后果就是慢很多。\t\t</div>",
      "date": "2024-04-01",
