      "is_folded": false,
      "answerer": {
        "username": "礼乐崩坏",
        "uid": "98388"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t加速是好事啊，厉害了我的包，包包加油，包包最棒啦\t\t</div>",
