    {
      "id": "630286",
      "is_folded": false,
      "answerer": {
        "username": "通商宽衣颐使气指",
        "uid": "74980"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t你小的時候責備你成績差不好好學習你看你們班誰誰誰數學考100分，你不要讀書了，去工地上班吧。你再敢頂嘴我今天抽死你<br/>\n長大了責備你沒錢你看我們村的誰誰誰的孩子都上國小了就你還沒有（男）女朋友，找不到對象就不要回家了\t\t</div>",
      "date": "2023-02-12",
      "agree_count": 5,
      "discussion_count": 1,
      "discussions": [
        {
          "id": "1154584",
          "replier": {
            "username": "习维尼法西斯",
            "uid": "103621"
