    {
      "id": "724650",
      "is_folded": false,
      "answerer": {
        "username": "吼姆啦的天才评论",
        "uid": "120548"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t支味盎然<br/>\n<br/>\n题主的逻辑是 只有党可以靠暴力夺取政权 用暴力镇压民众 <br/>\n民众不可以使用暴力反抗党<br/>\n<br/>\n只能州官放火 不让百姓点灯 赤裸裸的奴性宣传\t\t</div>",
      "date": "2024-01-30",
      "agree_count": 2,
