    {
      "id": "631300",
      "is_folded": false,
      "answerer": {
        "username": "[已注销]",
        "uid": null
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t非洲黑人开汽车和摩托车素质都比<mark>支那人</mark>好，而且乱闯红灯的现象也不多，比如赞比亚，南非，素质都比<mark>支那</mark>高\t\t</div>",
