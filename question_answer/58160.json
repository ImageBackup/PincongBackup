      "discussions": []
    },
    {
      "id": "653617",
      "is_folded": false,
      "answerer": {
        "username": "东亚灯塔",
        "uid": "92877"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t正经印度菜吃起来确实不赖，可惜那些自媒体为了博眼球满足中国人的民族情绪全整一些贫民窟卫生条件极差的小吃摊，就相当于介绍中餐跑去路边的地沟油苍蝇馆一样，自然而然就被污名化了。\t\t</div>",
      "date": "2023-05-08",
