    },
    {
      "id": "663056",
      "is_folded": false,
      "answerer": {
        "username": "Justitia",
        "uid": "42231"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t第一段就很翻譯腔，很像閱讀測驗，把including a,b,c跟形容詞子句的補充陳述列在後面。\t\t</div>",
      "date": "2023-06-16",
