    {
      "id": "631947",
      "is_folded": false,
      "answerer": {
        "username": "karamat",
        "uid": "26790"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t特朗普那个协议刚签就开始疫情，这三年其实是给了中国额外的三年的时间，产业链转移被暂停了\t\t</div>",
