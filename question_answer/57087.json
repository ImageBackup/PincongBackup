    {
      "id": "642220",
      "is_folded": false,
      "answerer": {
        "username": "月光",
        "uid": "89273"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t這種節目是給同溫層的人看的，<br/>\n目標觀眾不是中立選民，<br/>\n做節目的也不期待會拉到非同溫層的觀眾。<br/>\n所以還是把它們當作娛樂節目就好。<br/>\n<br/>\n真的想看有嚴謹的政論節目，<br/>\n那就要花時間篩選，<br/>\n平常人大都是不會看這個的。\t\t</div>",
      "date": "2023-03-23",
      "agree_count": 2,
      "discussion_count": 0,
      "discussions": []
