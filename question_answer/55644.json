    {
      "id": "626831",
      "is_folded": false,
      "answerer": {
        "username": "夜地精",
        "uid": "107440"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t你好楼主，你的经历让我感同身受，建议考虑下办美签，然后走政治BH的路。拿绿卡\t\t</div>",
      "date": "2023-02-01",
