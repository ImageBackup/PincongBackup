    {
      "id": "706785",
      "is_folded": false,
      "answerer": {
        "username": "OrphenOfKos",
        "uid": "73371"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t刚上来反腐我就对他有了强大的怀疑<br/>\n像江胡那样闷声大发财是常态 <br/>\n而反腐 根据我对于贵支自晚清以来的政治模式 绝对是选择性反腐来打击异己\t\t</div>",
      "date": "2023-11-20",
