      "is_folded": false,
      "answerer": {
        "username": "肖战嗦习维尼牛子",
        "uid": "84670"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t行程码可以用双卡绕过，而且伪造起来也特别容易，健康吗则绑定身份证。现在还有个场所码还要求扫码，以追踪出行地点，什么时候干掉场所码，才意味着真的转向了。<br/>\n<br/>\n虽然刹车坏了，但是方向盘还好着，突然180°转向还不用减速的。\t\t</div>",
      "date": "2022-12-11",
      "agree_count": 0,
      "discussion_count": 5,
      "discussions": [
        {
          "id": "1134776",
          "replier": {
