      "discussions": []
    },
    {
      "id": "628363",
      "is_folded": false,
      "answerer": {
        "username": "萨格尔王吃冰棒",
        "uid": "21463"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t不要尝试唤醒了，这两年现实都这么遭了还当粉红说明有认知障碍或者价值观本来就不正常。\t\t</div>",
