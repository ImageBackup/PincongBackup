    {
      "id": "703500",
      "is_folded": false,
      "answerer": {
        "username": "粉红个个该诛",
        "uid": "114291"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t一头肥猪，智障，学历低，又蠢又坏，恶心，妥妥的<mark>支那人</mark>。\t\t</div>",
      "date": "2023-11-05",
