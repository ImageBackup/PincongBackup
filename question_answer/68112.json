    {
      "id": "755996",
      "is_folded": false,
      "answerer": {
        "username": "吾儿禁评",
        "uid": "73706"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t一般人冒充不了，是不是<mark>支那</mark>官员人家能识别出来。纪委我不知道，但是我有同学在什么督察办，督察的时候人家还有专门的证件\t\t</div>",
      "date": "2024-06-24",
