    {
      "id": "620798",
      "is_folded": false,
      "answerer": {
        "username": "精肾细腻",
        "uid": "89684"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t东亚都是盐碱地，什么资源都没有，粮食都无法自给自足，不存在物博\t\t</div>",
      "date": "2023-01-14",
