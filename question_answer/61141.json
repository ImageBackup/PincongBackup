    {
      "id": "682406",
      "is_folded": false,
      "answerer": {
        "username": "四邑漁農牧工商總會",
        "uid": "7113"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t最近知乎看到個怪論，說趙武靈王胡服騎射和唐朝開放包容都是鄧時代吹噓出來的，為改革開放的合理性背書<br/>\n<br/>\n胡服騎射不是假，但沒必要故意吹噓到不合理的高度，軍事改革歷朝歷代都有，故意大書特書就是為當下的合理性背書，所以七夕可能也是類似，用歷史理據為當下找合理性，中國沒有情人節隨便從古代挪用個節日過來\t\t</div>",
      "date": "2023-08-23",
