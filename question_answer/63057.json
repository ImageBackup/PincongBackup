    {
      "id": "713357",
      "is_folded": false,
      "answerer": {
        "username": "xxyyzzss",
        "uid": "73609"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t瓷国人是唯结果论的，只要你最终赢了，过程、手段都会被认为是“本事”。\t\t</div>",
      "date": "2023-12-17",
