    {
      "id": "703103",
      "is_folded": false,
      "answerer": {
        "username": "刻有勇气的铭文",
        "uid": "113300"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t听说过没有对错只有立场吗？<br/>\n在粉红看来<br/>\n咱们读书人根本没有资格享受高福利待遇<br/>\n共产党用人民医院反腐清洗知识分子<br/>\n人家粉红都狂欢死了好嘛？\t\t</div>",
