      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "747203",
      "is_folded": false,
      "answerer": {
        "username": "幸福中国",
        "uid": "107007"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t被网暴了就报复回去<br/>\n开盒人肉，短信轰炸，电信轰炸，去个红灯区，在墙上写他的电话号，让嫖客天天给他打电话<br/>\n<br/>\n有手机号花钱开盒出身份证照片，拿照片去犯法<br/>\n<br/>\n开盒出去地址，拿地址去犯法<br/>\n<br/>\n开盒出他的社交账号，p图造谣<br/>\n<br/>\n等等，报复方式特别多\t\t</div>",
      "date": "2024-05-12",
      "agree_count": 0,
      "discussion_count": 2,
      "discussions": [
        {
          "id": "1264750",
