    {
      "id": "721200",
      "is_folded": false,
      "answerer": {
        "username": "billzhan",
        "uid": "88055"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t只要台灣還沒有被強佔的一天<br/>\n粉紅的自尊心就會一直受傷。<br/>\n自尊心永遠是第一重要的\t\t</div>",
