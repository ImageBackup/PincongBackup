    {
      "id": "721160",
      "is_folded": false,
      "answerer": {
        "username": "runner",
        "uid": "121529"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t我接触到的人，女权女和同性恋喜欢台湾的多，女权女是因为女权（台湾有女领袖），同性恋是因为台湾同婚合法。<br/>\n其他人大多仇恨台湾（他们就是一群狗，官方让他们往哪咬，就往哪咬）\t\t</div>",
      "date": "2024-01-18",
