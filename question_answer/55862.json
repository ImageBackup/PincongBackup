      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "628405",
      "is_folded": false,
      "answerer": {
        "username": "林肯",
        "uid": "21633"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t合理，人民尊重軍隊沒什麼好說的，但「中國人民解放軍」是黨衛隊，屬武裝家丁，不是軍人，拿人民的血汗錢卻效忠共匪地主階級，應該給予鄙視。\t\t</div>",
      "date": "2023-02-06",
