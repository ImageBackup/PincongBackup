    {
      "id": "730999",
      "is_folded": false,
      "answerer": {
        "username": "维尼大战美稀宗",
        "uid": "83055"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t虚空打靶？受过初中教育的年轻人都不至于看不懂，最多就是文字密度高的时候看起来有些吃力罢了。\t\t</div>",
      "date": "2024-02-29",
