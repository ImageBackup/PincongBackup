    {
      "id": "730995",
      "is_folded": false,
      "answerer": {
        "username": "球速体育",
        "uid": "125198"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t我的台湾朋友看简体字基本是无障碍阅读，打字是注音输入法，看不懂拼音，但是发音又对（除了带一点台湾腔）<br/>\n我自己看繁体字基本能看懂大半，但是感觉很累，速度也没简体字快，从小没学过，最多在新华字典里面看到过\t\t</div>",
      "date": "2024-02-29",
      "agree_count": 0,
      "discussion_count": 0,
      "discussions": []
