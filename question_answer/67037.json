    {
      "id": "745921",
      "is_folded": false,
      "answerer": {
        "username": "bdance",
        "uid": "83882"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t早说了男女关系之类的就是共匪拿来分化制造矛盾转移视线的 包括这个论坛上也是有人不停的拿这个当话题（当然我现在不排除本身就是水军）\t\t</div>",
      "date": "2024-05-06",
      "agree_count": 0,
      "discussion_count": 1,
      "discussions": [
        {
          "id": "1263259",
          "replier": {
            "username": "紅豆",
