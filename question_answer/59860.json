      "discussions": []
    },
    {
      "id": "669986",
      "is_folded": false,
      "answerer": {
        "username": "葱白",
        "uid": "94300"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t一线城市<br/>\n<br/>\n高级购物中心人流明显减少<br/>\n<br/>\n中级餐馆顾客明显减少<br/>\n<br/>\n小餐馆室外的啤酒烧烤明显减少\t\t</div>",
      "date": "2023-07-12",
