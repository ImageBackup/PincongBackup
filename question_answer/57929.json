      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "651496",
      "is_folded": false,
      "answerer": {
        "username": "valengosu",
        "uid": "106812"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t中国人缺乏把事情说清楚的能力 我从来没见过比我还善于解释清楚问题的人 所以我知道这一点 背后的原因是中国人缺乏逻辑 从小不教逻辑学\t\t</div>",
      "date": "2023-04-28",
