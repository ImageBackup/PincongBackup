      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "626077",
      "is_folded": false,
      "answerer": {
        "username": "禁评一世熊",
        "uid": "103456"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t将蒋公与毛匪并列者，若是台湾人尚可理解，若是大陆人则真是不识好歹。\t\t</div>",
      "date": "2023-01-30",
