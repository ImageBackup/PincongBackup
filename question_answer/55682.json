    {
      "id": "626049",
      "is_folded": false,
      "answerer": {
        "username": "陳家梁子",
        "uid": "74631"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t蒋是传统型帝王，只是君不是师。毛是新型的帝王范式，君师合一。洪秀全和孙中山与毛同款。洪成功了一半，孙没有成功，毛最成功。\t\t</div>",
      "date": "2023-01-30",
