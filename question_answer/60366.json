      "discussions": []
    },
    {
      "id": "674997",
      "is_folded": false,
      "answerer": {
        "username": "洼地先知",
        "uid": "102273"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t粉蛆还有一句话叫：<br/>\n<br/>\n有钱在哪都滋润，没钱在哪都是底层。<br/>\n<br/>\n这句话偷换了概念。<br/>\n<br/>\n人活着的目的就是按照上帝的心意，平静过完一生<br/>\n<br/>\n这个和穷富关系不大<br/>\n<br/>\n在欧美，即使穷，既是底层，依然能够吃饱穿暖<br/>\n<br/>\n但在<mark>支那</mark>，有钱也只是不断穷奢极欲，榨取别人的价值\t\t</div>",
      "date": "2023-07-30",
      "agree_count": 19,
      "discussion_count": 3,
