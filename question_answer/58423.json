      "discussion_count": 0,
      "discussions": []
    },
    {
      "id": "834670",
      "is_folded": false,
      "answerer": {
        "username": "隔岸觀火",
        "uid": "102219"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t火箭軍司令貪污率百分之百，那當然是崇拜無比\t\t</div>",
      "date": "2025-11-07",
