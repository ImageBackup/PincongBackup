    {
      "id": "775102",
      "is_folded": false,
      "answerer": {
        "username": "衡匡偷光",
        "uid": "111241"
      },
      "contents": "<div class=\"markitup-box\">\n\t\t\t不接受自己的国家很弱，只能吹强，甚至在这里都能找到，共军武器装备生产线一条龙齐备的言论\t\t</div>",
      "date": "2024-09-18",
