le=\"max-width:100%\"/></a><br/>\n<br/>\n<a class=\"placeholder\" href=\"url/img/aHR0cHM6Ly91cGxvYWQud2lraW1lZGlhLm9yZy93aWtpcGVkaWEvY29tbW9ucy9hL2FkLyUyODIwMjMwNjIwJTI5XyVFNyVCQSVBMiVFOCVBMSVBMyVFNCVCOCVBRCVFNSU5QiVCRCVFNCVCQSVCQSVFNiU5RiU4RiVFNiU5RSU5NyVFNiVBQyVBMiVFOCVCRiU4RSVFNiU5RCU4RSVFNSVCQyVCQS5qcGc\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://upload.wikimedia.org/wikipedia/commons/a/ad/%2820230620%29_%E7%BA%A2%E8%A1%A3%E4%B8%AD%E5%9B%BD%E4%BA%BA%E6%9F%8F%E6%9E%97%E6%AC%A2%E8%BF%8E%E6%9D%8E%E5%BC%BA.jpg\"><img alt=\"https://upload.wikimedia.org/wikipedia/commons/a/ad/%2820230620%29_%E7%BA%A2%E8%A1%A3%E4%B8%AD%E5%9B%BD%E4%BA%BA%E6%9F%8F%E6%9E%97%E6%AC%A2%E8%BF%8E%E6%9D%8E%E5%BC%BA.jpg\" loading=\"lazy\" src=\"https://upload.wikimedia.org/wikipedia/commons/a/ad/%2820230620%29_%E7%BA%A2%E8%A1%A3%E4%B8%AD%E5%9B%BD%E4%BA%BA%E6%9F%8F%E6%9E%97%E6%AC%A2%E8%BF%8E%E6%9D%8E%E5%BC%BA.jpg\" style=\"max-width:100%\"/></a><br/>\n<br/>\r\n凤凰卫视的报导 <a href=\"url/link/aHR0cHM6Ly93d3cueW91dHViZS5jb20vd2F0Y2g_dj02eHkzX1Z3eVZ3dw\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://www.youtube.com/watch?v=6xy3_VwyVww\">https://www.youtube.com/watch?v=6xy3_VwyVww</a><br/>\n<br/>\n<br/>\n<br/>\n<b>李强肖尔茨会谈 示威者支持李强接班习近平</b><br/>\n<br/>\n<br/>\r\n【2023年6月22日讯】<br/>\n<br/>\r\n6月20日，德国总理肖尔茨（Olaf Scholz）在总理府会见到访的中国总理李强。总理府外有大批示威者聚集，其中有人举起标语，支持李强接班习近平。<br/>\n<br/>\r\n当地时间6月20日上午，李强抵达位于首都柏林的德国总理府，在肖尔茨的陪同下共同检阅仪仗队。<br/>\n<br/>\r\n根据现场图片，总理府外有大批示威者聚集，部分香港人、藏人、维吾尔人及法轮功信众在场抗议，声讨中国政府的迫害，要求德国政府实行更严厉的对华政策。<br/>\n<br/>\r\n现场亦有戴着墨镜和口罩、身着红衣人士欢迎李强，其中有人举起标语：“浙江总商会 拥护李强 接班习近平”、“2027 习下李上 李强接班 德国温州同乡会支持李强”。<br/>\n<br/>\r\n目前中德双方均未作出回应。<br/>\n<br/>\n<b>（浙江宣传王纲）</b><br/>\n<br/>\n<a href=\"url/link/aHR0cHM6Ly96aC53aWtpbmV3cy5vcmcvdy9pbmRleC5waHA_dGl0bGU9JUU2JTlEJThFJUU1JUJDJUJBJUU4JTgyJTk2JUU1JUIwJTk0JUU4JThDJUE4JUU0JUJDJTlBJUU4JUIwJTg4XyVFNyVBNCVCQSVFNSVBOCU4MSVFOCU4MCU4NSVFNiU5NCVBRiVFNiU4QyU4MSVFNiU5RCU4RSVFNSVCQyVCQSVFNiU4RSVBNSVFNyU4RiVBRCVFNCVCOSVBMCVFOCVCRiU5MSVFNSVCOSVCMyZvbGRpZD0yMzI4NzU\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://zh.wikinews.org/w/index.php?title=%E6%9D%8E%E5%BC%BA%E8%82%96%E5%B0%94%E8%8C%A8%E4%BC%9A%E8%B0%88_%E7%A4%BA%E5%A8%81%E8%80%85%E6%94%AF%E6%8C%81%E6%9D%8E%E5%BC%BA%E6%8E%A5%E7%8F%AD%E4%B9%A0%E8%BF%91%E5%B9%B3&amp;oldid=232875\">https://zh.wikinews.org/w/index.php?title=%E6%9D%8E%E5%BC%BA%E8%82%96%E5%B0%94%E8%8C%A8%E4%BC%9A%E8%B0%88_%E7%A4%BA%E5%A8%81%E8%80%85%E6%94%AF%E6%8C%81%E6%9D%8E%E5%BC%BA%E6%8E%A5%E7%8F%AD%E4%B9%A0%E8%BF%91%E5%B9%B3&amp;oldid=232875</a><br/>\n<a href=\"url/link/aHR0cHM6Ly96aC53aWtpbmV3cy5vcmcvd2lraS8lRTYlOUQlOEUlRTUlQkMlQkElRTglODIlOTYlRTUlQjAlOTQlRTglOEMlQTglRTQlQkMlOUElRTglQjAlODhfJUU3JUE0JUJBJUU1JUE4JTgxJUU4JTgwJTg1JUU2JTk0JUFGJUU2JThDJTgxJUU2JTlEJThFJUU1JUJDJUJBJUU2JThFJUE1JUU3JThGJUFEJUU0JUI5JUEwJUU4JUJGJTkxJUU1JUI5JUIz\" rel=\"nofollow noreferrer noopener\" target=\"_blank\" title=\"https://zh.wikinews.org/wiki/%E6%9D%8E%E5%BC%BA%E8%82%96%E5%B0%94%E8%8C%A8%E4%BC%9A%E8%B0%88_%E7%A4%BA%E5%A8%81%E8%80%85%E6%94%AF%E6%8C%81%E6%9D%8E%E5%BC%BA%E6%8E%A5%E7%8F%AD%E4%B9%A0%E8%BF%91%E5%B9%B3\">https://zh.wikinews.org/wiki/%E6%9D%8E%E5%BC%BA%E8%82%96%E5%B0%94%E8%8C%A8%E4%BC%9A%E8%B0%88_%E7%A4%BA%E5%A8%81%E8%80%85%E6%94%AF%E6%8C%81%E6%9D%8E%E5%BC%BA%E6%8E%A5%E7%8F%AD%E4%B9%A0%E8%BF%91%E5%B9%B3</a><br/>\n<br/>\n<br/>\n<br/>\n<br/>\n<br/>\r\n电报群看到的<br/>\r\n浙江人想造反？<br/>\r\nΣ(°ロ°) (⊙_⊙)\t\t\t\t\t\t\t</div>",
